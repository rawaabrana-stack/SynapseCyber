# Copy this file to .env.local and fill in SMTP_PASS.
# .env.local is gitignored and must never be committed.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@gmail.com
# Gmail App Password (16 chars, generated at https://myaccount.google.com/apppasswords)
SMTP_PASS=your_16_char_app_password
# Where form submissions are delivered (defaults to SMTP_USER)
MAIL_TO=you@gmail.com
MAIL_FROM=you@gmail.com
